# Discord
DISCORD_TOKEN=put_discord_bot_token_here
# Opcjonalne: do linkow zaproszenia, bot sam ustala ID aplikacji po tokenie.
DISCORD_CLIENT_ID=put_discord_client_id_here
DISCORD_GUILD_ID=put_discord_guild_id_here
# Ustaw true tylko po wlaczeniu tych opcji w Discord Developer Portal.
DISCORD_ENABLE_GUILD_MEMBERS_INTENT=false
DISCORD_ENABLE_MESSAGE_CONTENT_INTENT=false
DATA_DIR=/app/data
LOG_DIR=/app/logs

# PUBG
PUBG_API_KEY=put_pubg_api_key_here
PUBG_PLATFORM=steam
PUBG_REGION=steam
PUBG_CLAN_ID=clan.4708615947dc483c871621fc3b24590f

# Twitch. Najlepiej podac CLIENT_ID + CLIENT_SECRET, bot sam pobierze access token.
TWITCH_CLIENT_ID=put_twitch_client_id_here
TWITCH_CLIENT_SECRET=put_twitch_client_secret_here

# Google Sheets
GOOGLE_SPREADSHEET_ID=put_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_FILE=/app/secrets/google-service-account.json

# WordPress
WP_USER=Sentinel
WP_APP_PASSWORD=put_wordpress_application_password_here
WP_PAGE_URL=https://nationaldevils.eu/wp-json/wp/v2/pages/123
WP_CLAN_ENDPOINT=http://192.168.0.121/wp-json/devs/v1/klan
WP_CLAN_PROMOTION_ENDPOINT=http://192.168.0.121/wp-json/devs/v1/klan-promotion
WP_TIP_ENDPOINT=http://192.168.0.121/wp-json/nationaldevils/v1/tip
WP_EVENTS_URL=http://192.168.0.121/wp-json/nd/v1
WP_EVENTS_TOKEN=put_wordpress_events_token_here

# Inne integracje
TIPPLY_WIDGET_URL=https://widgets.tipply.pl/TIP_ALERT/your-widget-id/
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
